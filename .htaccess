# Protect sensitive files from direct access
<Files ".env">
Order allow,deny
Deny from all
</Files>

<Files "composer.json">
Order allow,deny
Deny from all
</Files>

<Files "composer.lock">
Order allow,deny
Deny from all
</Files>

# Deny access to database directory
<Files ~ "\.sqlite$">
Order allow,deny
Deny from all
</Files>

# Deny access to SQL schema files
<Files ~ "\.sql$">
Order allow,deny
Deny from all
</Files>

# Protect Invoice Email API configuration and logs
<Files "config.php">
Order allow,deny
Deny from all
</Files>

<Files ~ "\.log$">
Order allow,deny
Deny from all
</Files>

<Files "error_log.txt">
Order allow,deny
Deny from all
</Files>

<Files "rate_limits.json">
Order allow,deny
Deny from all
</Files>

# Protect database directory and vendor/cron internals
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^database/ - [F,L]
    RewriteRule ^vendor/ - [F,L]
    RewriteRule ^cron/logs/ - [F,L]
    # Stored telemetry + crash reports are read only by the authenticated admin
    # pages (via the filesystem), never served as static files. The endpoints
    # write here over the filesystem too, so blocking web access is safe.
    RewriteRule ^admin/data-logs/ - [F,L]
</IfModule>

# Prevent directory listing
Options -Indexes

# Set default character set
AddDefaultCharset UTF-8

# Protect against XSS attacks and set security policy
<IfModule mod_headers.c>
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    Header set X-XSS-Protection "1; mode=block"
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Content Security Policy
    Header set Content-Security-Policy "default-src 'self'; \
        script-src 'self' 'unsafe-inline' 'unsafe-eval' \
            https://cdnjs.cloudflare.com \
            https://s3-us-west-2.amazonaws.com \
            https://www.paypal.com \
            https://*.paypal.com \
            https://www.sandbox.paypal.com \
            https://*.paypalobjects.com \
            https://js.stripe.com \
            https://*.stripe.com \
            https://sandbox.web.squarecdn.com \
            https://web.squarecdn.com \
            https://*.squarecdn.com \
            https://*.squareup.com \
            https://www.googletagmanager.com \
            https://*.googletagmanager.com \
            https://www.google-analytics.com \
            https://*.google-analytics.com \
            https://googleads.g.doubleclick.net \
            https://*.doubleclick.net; \
        style-src 'self' 'unsafe-inline' \
            https://argorobots.com \
            https://dev.argorobots.com \
            https://fonts.googleapis.com \
            https://cdnjs.cloudflare.com \
            https://*.paypalobjects.com \
            https://*.stripe.com \
            https://*.squarecdn.com \
            https://*.squareup.com; \
        font-src 'self' \
            https://fonts.gstatic.com \
            https://cdnjs.cloudflare.com \
            https://*.paypalobjects.com \
            https://*.stripe.com \
            https://*.squarecdn.com \
            https://*.cloudfront.net; \
        img-src 'self' data: \
            https://argorobots.com \
            https://dev.argorobots.com \
            https://starterbest.com \
            https://dayslaunch.com \
            https://saasfame.com \
            https://deeplaunch.io \
            https://directoryhunt.org \
            https://proofstories.io \
            https://dofollow.tools \
            https://open-launch.com \
            https://s3-us-west-2.amazonaws.com \
            https://chart.googleapis.com \
            https://*.paypalobjects.com \
            https://*.paypal.com \
            https://*.stripe.com \
            https://*.squarecdn.com \
            https://*.squareup.com \
            https://www.google-analytics.com \
            https://*.google-analytics.com \
            https://googleads.g.doubleclick.net \
            https://*.doubleclick.net; \
        frame-src \
            https://www.youtube.com \
            https://www.youtube-nocookie.com \
            https://www.paypal.com \
            https://*.paypal.com \
            https://www.sandbox.paypal.com \
            https://*.sandbox.paypal.com \
            https://js.stripe.com \
            https://*.stripe.com \
            https://*.stripe.network \
            https://*.squarecdn.com \
            https://*.squareup.com \
            https://td.doubleclick.net \
            https://*.doubleclick.net \
            https://www.googletagmanager.com \
            https://*.googletagmanager.com; \
        connect-src 'self' \
            https://formspree.io \
            https://www.paypal.com \
            https://*.paypal.com \
            https://www.sandbox.paypal.com \
            https://*.sandbox.paypal.com \
            https://*.paypalobjects.com \
            https://api.stripe.com \
            https://*.stripe.com \
            https://checkout.stripe.com \
            https://connect.squareup.com \
            https://*.squareup.com \
            https://api.squareup.com \
            https://*.squarecdn.com \
            https://sandbox.web.squarecdn.com \
            https://web.squarecdn.com \
            https://pci-connect.squareupsandbox.com \
            https://pci-connect.squareup.com \
            https://*.squareupsandbox.com \
            https://www.google-analytics.com \
            https://*.google-analytics.com \
            https://analytics.google.com \
            https://googleads.g.doubleclick.net \
            https://*.doubleclick.net \
            https://stats.g.doubleclick.net \
            https://www.googletagmanager.com \
            https://*.googletagmanager.com \
            https://www.google.com \
            https://googleleads.g.doubleclick.net \
            https://td.doubleclick.net \
            https://www.google.com/ccm/collect \
            https://www.google.com/pagead/1p-conversion \
            https://www.google.com/pagead/viewthroughconversion \
            https://googleleads.g.doubleclick.net/pagead/viewthroughconversion \
            https://www.google.com/pagead/1p-conversion;"
    
    # Add Cache Control for better performance
    <FilesMatch "\.(html|htm|js|css)$">
        Header set Cache-Control "max-age=3600, must-revalidate"
    </FilesMatch>
    
    <FilesMatch "\.(ico|pdf|jpg|jpeg|png|gif|svg)$">
        Header set Cache-Control "max-age=86400, public"
    </FilesMatch>
    
    # Force download for executable files
    <FilesMatch "\.(exe|msi)$">
        Header set Content-Type "application/octet-stream"
        Header set Content-Disposition "attachment"
    </FilesMatch>

    # Force download for cross-platform installer files
    <FilesMatch "\.(AppImage|dmg|pkg)$">
        Header set Content-Type "application/octet-stream"
        Header set Content-Disposition "attachment"
    </FilesMatch>

    # Force download for Excel and Word invoice templates
    <FilesMatch "\.(xlsx|docx)$">
        Header set Content-Disposition "attachment"
    </FilesMatch>
</IfModule>

# Redirect to error pages
ErrorDocument 400 /error-pages/400.html
ErrorDocument 401 /error-pages/401.html
ErrorDocument 403 /error-pages/403.html
ErrorDocument 404 /error-pages/404.html
ErrorDocument 500 /error-pages/500.html
ErrorDocument 503 /error-pages/503.html

# PHP error handling
php_flag display_errors Off
php_flag log_errors On
php_value error_log error_log.txt

# Allow large POST bodies for AI vision requests (base64 images)
php_value post_max_size 10M
php_value upload_max_filesize 10M

# Rewrite rules
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Forward the Authorization header to PHP so HTTP Basic Auth works under
    # PHP-FPM/CGI (used only by the dev staging gate; harmless on production,
    # which sends no Authorization header and has no gate active).
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Protect database directory
    RewriteRule ^database/ - [F,L]
    
    # --- Customer Payment Portal routes ---

    # Invoice view: /invoice/{48-char-hex-token}
    RewriteRule ^invoice/([a-fA-F0-9]{48})/?$ portal/invoice.php?token=$1 [L,QSA]

    # Customer portal: /portal/{48-char-hex-token}
    RewriteRule ^portal/([a-fA-F0-9]{48})/?$ portal/index.php?token=$1 [L,QSA]

    # Portal API: registration
    RewriteRule ^api/portal/register/?$ api/portal/register.php [L,QSA]

    # AI completions proxy
    RewriteRule ^api/ai/completions/?$ api/ai/completions.php [L,QSA]

    # Exchange rates proxy
    RewriteRule ^api/exchange-rates/?$ api/exchange-rates.php [L,QSA]

    # Google OAuth and Sheets proxy
    RewriteRule ^api/google/auth/?$ api/google/auth.php [L,QSA]
    RewriteRule ^api/google/callback/?$ api/google/callback.php [L,QSA]
    RewriteRule ^api/google/sheets/export/?$ api/google/sheets/export.php [L,QSA]

    # Portal API: company name update
    RewriteRule ^api/portal/company-name/?$ api/portal/company-name.php [L,QSA]

    # Portal API: company logo upload/delete
    RewriteRule ^api/portal/logo/?$ api/portal/logo.php [L,QSA]

    # Portal API: status check
    RewriteRule ^api/portal/status/?$ api/portal/status.php [L,QSA]

    # Portal API: invoice publishing
    RewriteRule ^api/portal/invoices/?$ api/portal/invoices.php [L,QSA]

    # Portal API: payment sync (GET = pull, POST = confirm; confirm path also routes here)
    RewriteRule ^api/portal/payments/sync/confirm/?$ api/portal/payments-sync.php [L,QSA]
    RewriteRule ^api/portal/payments/sync/?$ api/portal/payments-sync.php [L,QSA]

    # Provider OAuth callback: /api/portal/connect/callback/{provider}
    RewriteRule ^api/portal/connect/callback/(stripe|paypal|square)/?$ api/portal/connect-callback.php?provider=$1 [L,QSA]

    # Provider connect/disconnect: /api/portal/connect/{provider}
    RewriteRule ^api/portal/connect/(stripe|paypal|square)/?$ api/portal/connect.php?provider=$1 [L,QSA]

    # Portal payment webhooks: /api/portal/webhooks/{provider}
    RewriteRule ^api/portal/webhooks/(stripe|paypal|square)/?$ api/portal/webhooks/$1.php [L,QSA]

    # Telemetry data upload
    RewriteRule ^api/data/upload/?$ api/data/upload.php [L,QSA]

    # Desktop app crash reports
    RewriteRule ^api/data/crash/?$ api/data/crash.php [L,QSA]

    # --- Avalonia (cross-platform) download routes ---

    # Versioned: /download/avalonia/2.1.0/win
    RewriteRule ^download/avalonia/([0-9]+\.[0-9]+\.[0-9]+)/(win|mac|linux)/?$ get_avalonia_installer.php?version=$1&platform=$2 [L,QSA]

    # Latest: /download/avalonia/win
    RewriteRule ^download/avalonia/(win|mac|linux)/?$ get_avalonia_installer.php?platform=$1 [L,QSA]

    # --- Free invoice generator niche pages ---

    # Niche page: /free-invoice-generator/{slug} (lowercase letters, digits, hyphens)
    # Empty slug falls through to free-invoice-generator/index.php via DirectoryIndex.
    RewriteRule ^free-invoice-generator/([a-z0-9-]+)/?$ niches/niche-page.php?slug=$1 [L,QSA]

    # --- Free invoice generator template library ---

    # Template page: /invoice-template/{slug}/ (lowercase letters, digits, hyphens).
    # Hub /invoice-template/ falls through to invoice-template/index.php via DirectoryIndex.
    RewriteRule ^invoice-template/([a-z0-9-]+)/?$ invoice-template/template-page.php?slug=$1 [L,QSA]

    # Sitemap: served as static-looking XML, generated by PHP on each hit.
    RewriteRule ^sitemap\.xml$ sitemap.xml.php [L]

    # The invoice-guides hub was generalized and moved to /guides/.
    RewriteRule ^invoice-guides/?$ /guides/ [R=301,L]

    # Legacy URLs Google still has indexed from the old site structure.
    # 301 them to their current homes so the old links keep their value
    # instead of returning 404 and getting dropped from the index.
    RewriteRule ^download\.php$ /downloads/ [R=301,L]
    RewriteRule ^download/?$ /downloads/ [R=301,L]
    RewriteRule ^contact\.php$ /contact-us/ [R=301,L]
    RewriteRule ^index\.html$ / [R=301,L]

    # Renamed pages (old slugs Google still has crawled).
    RewriteRule ^features/ai-spreadsheet-import/?$ /features/spreadsheet-import/ [R=301,L]
    RewriteRule ^upgrade(/index\.php)?/?$ /pricing/ [R=301,L]

    # --- Free invoice generator informational articles ---

    # Each article URL is an exact slug at root. Listed explicitly so we do
    # not shadow other root-level pages with a wildcard rule.
    RewriteRule ^how-to-invoice-clients/?$ articles/article-page.php?slug=how-to-invoice-clients [L,QSA]
    RewriteRule ^net-30-vs-due-on-receipt/?$ articles/article-page.php?slug=net-30-vs-due-on-receipt [L,QSA]
    RewriteRule ^invoice-numbering-best-practices/?$ articles/article-page.php?slug=invoice-numbering-best-practices [L,QSA]
    RewriteRule ^what-to-include-on-an-invoice/?$ articles/article-page.php?slug=what-to-include-on-an-invoice [L,QSA]
    RewriteRule ^late-fees-when-and-how-to-charge/?$ articles/article-page.php?slug=late-fees-when-and-how-to-charge [L,QSA]
    RewriteRule ^tax-on-invoices-country-guide/?$ articles/article-page.php?slug=tax-on-invoices-country-guide [L,QSA]
    RewriteRule ^what-to-do-when-a-client-does-not-pay/?$ articles/article-page.php?slug=what-to-do-when-a-client-does-not-pay [L,QSA]
    RewriteRule ^how-to-follow-up-on-unpaid-invoices/?$ articles/article-page.php?slug=how-to-follow-up-on-unpaid-invoices [L,QSA]
    RewriteRule ^recurring-invoices-when-to-use-them/?$ articles/article-page.php?slug=recurring-invoices-when-to-use-them [L,QSA]
    RewriteRule ^free-vs-paid-invoicing-tools/?$ articles/article-page.php?slug=free-vs-paid-invoicing-tools [L,QSA]
    RewriteRule ^best-free-ai-receipt-scanner/?$ articles/article-page.php?slug=best-free-ai-receipt-scanner [L,QSA]
    RewriteRule ^best-quickbooks-alternatives/?$ articles/article-page.php?slug=best-quickbooks-alternatives [L,QSA]
    RewriteRule ^bookkeeping-for-contractors/?$ articles/article-page.php?slug=bookkeeping-for-contractors [L,QSA]
    RewriteRule ^how-to-send-an-invoice-for-free/?$ articles/article-page.php?slug=how-to-send-an-invoice-for-free [L,QSA]
    RewriteRule ^bookkeeping-for-rental-businesses/?$ articles/article-page.php?slug=bookkeeping-for-rental-businesses [L,QSA]
    RewriteRule ^inventory-tracking-for-small-businesses/?$ articles/article-page.php?slug=inventory-tracking-for-small-businesses [L,QSA]
    RewriteRule ^how-to-track-business-expenses-without-spreadsheets/?$ articles/article-page.php?slug=how-to-track-business-expenses-without-spreadsheets [L,QSA]
    RewriteRule ^best-free-accounting-software-for-small-business/?$ articles/article-page.php?slug=best-free-accounting-software-for-small-business [L,QSA]
    RewriteRule ^small-business-tax-deductions/?$ articles/article-page.php?slug=small-business-tax-deductions [L,QSA]
    RewriteRule ^bookkeeping-for-cleaning-companies/?$ articles/article-page.php?slug=bookkeeping-for-cleaning-companies [L,QSA]
    RewriteRule ^small-business-bookkeeping-basics/?$ articles/article-page.php?slug=small-business-bookkeeping-basics [L,QSA]
    RewriteRule ^bookkeeping-for-landscapers/?$ articles/article-page.php?slug=bookkeeping-for-landscapers [L,QSA]
    RewriteRule ^best-invoicing-software-for-small-business/?$ articles/article-page.php?slug=best-invoicing-software-for-small-business [L,QSA]
</IfModule>